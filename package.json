{
  "name": "ssh-todolist-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "web:serve": "vite --host 127.0.0.1 --port 4173",
    "mobile:prepare": "vite build --outDir mobile/www --emptyOutDir",
    "android:add": "npm run mobile:prepare && npx cap add android",
    "android:sync": "npm run mobile:prepare && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "node scripts/build_android.mjs debug",
    "android:build:release": "node scripts/build_android.mjs release",
    "android:build:aab": "node scripts/build_android.mjs bundle",
    "android:keystore": "node scripts/generate_keystore.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
